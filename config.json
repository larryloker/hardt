{
    "agent_name": "LARRY G-FORCE",
    "version": "3.0.0",
    "_comment": "Canonical config for the restructured agent (main.py, subagents/, tools/, utils/). Legacy modules still read larry_config.json.",
    "ollama": {
        "host": "http://localhost:11434",
        "num_parallel": 1,
        "keep_alive": "30m",
        "timeout": 1800
    },
    "models": {
        "_comment": "Roles mapped to installed models (2026-07-06). main=qwen3.6:35b (largest, GPU+CPU split, num_gpu=16 in larry_config). Small models (fast/embedding) stay CPU-resident. Custom LocalLarry-* absent (need Modelfiles, D1); repoint once built.",
        "main": "qwen3.6:35b",
        "fast": "qwen3:latest",
        "uncensored": "devstral-small-2:latest",
        "embedding": "nomic-embed-text:latest",
        "telegram_default": "qwen3:latest",
        "fallbacks": {
            "qwen3.6:35b": "qwen3-coder:latest",
            "qwen3-coder:latest": "qwen3:latest",
            "qwen3:latest": "lfm2.5:latest",
            "devstral-small-2:latest": "qwen3:latest"
        }
    },
    "subagents": {
        "executor":   { "model": "main",       "max_turns": 8 },
        "editor":     { "model": "main",       "max_turns": 6 },
        "searcher":   { "model": "fast",       "max_turns": 4 },
        "transcribe": { "model": "fast",       "max_turns": 4 },
        "debugger":   { "model": "main",       "max_turns": 10 }
    },
    "paths": {
        "memory_dir": "memory",
        "chroma_db": "memory/chroma_db",
        "tasks_db": "memory/tasks.db",
        "skills_db": "memory/skills.db",
        "sessions_db": "memory/sessions.db",
        "logs_dir": "logs",
        "sandbox_dir": "sandbox"
    },
    "orchestrator": {
        "model": "main",
        "max_steps": 6,
        "use_memory": true
    },
    "api": {
        "_comment": "host/port for the HTTP API. token: null = use env LARRY_API_TOKEN, else auto-generate and print at startup. Set a string here to pin one.",
        "host": "127.0.0.1",
        "port": 7333,
        "token": null
    },
    "model_management": {
        "_comment": "keep_loaded models are never unloaded by the orchestrator (prefer keeping the small fast model + embedder resident; the big main model gets evicted first).",
        "keep_loaded": ["qwen3", "nomic-embed-text"],
        "vram_unload_threshold_percent": 78.0
    },
    "terminal": {
        "timeout": 120,
        "working_dir": null
    },
    "features": {
        "telegram_enabled": true,
        "rag_enabled": true,
        "voice_enabled": false
    },
    "logging": {
        "level": "INFO",
        "file": "logs/larry.log"
    }
}
