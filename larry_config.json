{
    "agent_name": "LARRY G-FORCE",
    "version": "2.0.0",
    "_working_directory_comment": "Leave null for portable mode — larry_paths.BASE_DIR is used (the dir containing agent_v2.py). Set to an absolute path only to override.",
    "working_directory": null,
    "hardware": {
        "mode": "GPU",
        "ram_gb": 64,
        "ram_type": "DDR5",
        "gpu": "RTX 4060 8GB",
        "gpu_used_for": "LLM inference + reranker (CUDA_VISIBLE_DEVICES=0)",
        "cuda_visible_devices": "0",
        "gpu_power_limit_w": 100,
        "gpu_persistence_mode": true
    },
    "gpu_gaming": {
        "_comment": "When gaming_mode is true, model_router clamps Ollama num_gpu (GPU transformer-layer offload) to gaming_num_gpu so the RTX 4060's VRAM + compute stay free for games; remaining layers run on the 64GB DDR5 via CPU. gaming_num_gpu=16 is ~half of dolphin3:8b's 32 layers (~50% GPU, ~2.5-3GB VRAM). Lower = more game headroom but slower tokens. Toggle live with no restart: set gaming_mode false for full-speed inference.",
        "gaming_mode": false,
        "gaming_num_gpu": 16
    },
    "ollama": {
        "host": "http://localhost:11434",
        "default_model": "qwen3.6:35b",
        "embedding_model": "nomic-embed-text:latest",
        "timeout": 1800,
        "num_parallel": 1,
        "keep_alive": "30m",
        "num_gpu": 10,
        "_num_gpu_comment": "qwen3.6:35b (main, ~23GB) exceeds 8GB VRAM: 10 transformer layers on the RTX 4060, the rest on 64GB DDR5 (GPU+CPU split). Tuned live 2026-07-06: num_gpu 12 -> 7.4GB/72-28 split OK, 16 -> cudaMalloc OOM. 10 chosen for headroom (desktop compositor + browser also use VRAM). Small models (qwen3, lfm2.5, embedder) stay CPU-resident via keep_loaded.",
        "cli_default_model": "qwen3.6:35b",
        "telegram_default_model": "qwen3:latest"
    },
    "profiles": {
        "default": "ACCURACY",
        "available": [
            "SPEED",
            "BALANCED",
            "ACCURACY",
            "ULTRA_CONTEXT"
        ],
        "hardware_mode": "CPU_DDR5_64GB",
        "flagship_model": "qwen3.6:35b",
        "coding_model": "qwen3-coder:latest",
        "fast_model": "qwen3:latest",
        "ultra_context_model": "qwen3.6:35b",
        "tier1_models": [
            "qwen3.6:35b",
            "qwen3-coder:latest"
        ],
        "tier2_models": [
            "devstral-small-2:latest"
        ],
        "tier3_fast_models": [
            "qwen3:latest",
            "lfm2.5:latest"
        ],
        "tier4_tiny_models": [
            "lfm2.5:latest"
        ]
    },
    "features": {
        "voice_enabled": false,
        "mcp_enabled": true,
        "rag_enabled": true,
        "telegram_enabled": true,
        "web_ui_enabled": false
    },
    "rag": {
        "backend": "chroma",
        "chroma_path": "./memory/chroma_db",
        "embedding_model": "nomic-embed-text:latest",
        "chunk_size": 800,
        "chunk_overlap": 250,
        "reranker_model": "BAAI/bge-reranker-v2-m3",
        "reranker_device": "cuda:0"
    },
    "database": {
        "sqlite_path": "./data/unified_context.db",
        "memory_path": "./memory.json"
    },
    "mcp": {
        "config_path": "./mcp.json",
        "timeout": 60
    },
    "logging": {
        "level": "INFO",
        "file": "./logs/larry.log"
    },
    "ui": {
        "theme": "gold1",
        "show_thinking": true,
        "show_tool_calls": true
    }
}